{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "modules",
    "apps/*"
  ],
  "scripts": {
    "dev:checkout": "cd apps/checkout && npm run dev",
    "dev:admin": "cd apps/admin && npm run dev -- --port 5174",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "cd apps/checkout && npm run test:integration",
    "test:browser": "cd apps/checkout && npm run test:browser",
    "test:e2e": "cd apps/checkout && npm run test:e2e"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
