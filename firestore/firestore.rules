rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Custom claims set by syncCustomClaims Cloud Function
      // when user doc roles[] includes "admin"
      return isSignedIn() && request.auth.token.get('admin', false) == true;
    }

    // The `actsAs` claim is set by verifyTagCheckout on the synthetic-UID
    // custom token used for kiosk badge sessions. It names the real user
    // doc the session is authorized to operate on. Empty string for
    // non-tag sessions.
    function actsAs() {
      return isSignedIn() ? request.auth.token.get('actsAs', '') : '';
    }

    // True for sessions created by Firebase Anonymous Auth
    // (signInAnonymously). The truly-anonymous checkout path uses these
    // — each session has a fresh UID, so rules can scope writes per
    // session even when there's no underlying user record.
    function isAnonymousAuth() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Whether the caller is authorized to act on a checkout owned by the
    // user pointed to by `userRef`. Either a real login (uid == doc.id)
    // or a tag-tap session (actsAs claim == doc.id).
    function isCheckoutPrincipalFor(userRef) {
      return isSignedIn() && (
        userRef == /databases/$(database)/documents/users/$(request.auth.uid) ||
        (actsAs() != '' && userRef == /databases/$(database)/documents/users/$(actsAs()))
      );
    }

    // Validation helpers
    function isDocumentReference(field, collection) {
      return field is path;
    }

    function isDocumentReferenceArray(arr, collection) {
      return arr is list && arr.size() >= 0;
    }

    // Validate billing address has all required fields
    function hasValidBillingAddress(data) {
      return data.billingAddress is map &&
             data.billingAddress.company is string && data.billingAddress.company.size() > 0 &&
             data.billingAddress.street is string && data.billingAddress.street.size() > 0 &&
             data.billingAddress.zip is string && data.billingAddress.zip.size() > 0 &&
             data.billingAddress.city is string && data.billingAddress.city.size() > 0;
    }

    // Validate user profile: firma users must have billing address
    function isValidUserProfile(data) {
      return data.userType != 'firma' || hasValidBillingAddress(data);
    }

    // Item-pricing field validation. Server-side recompute in
    // closeCheckoutAndGetPayment is the authoritative defense; this is a
    // cheap rule-level guard that rejects negative quantities/prices and
    // non-finite values (Infinity / NaN). The `is number` check passes
    // for non-finite values, so the explicit < bound is what catches
    // them: `Infinity < 1e308` is false, `NaN < anything` is false.
    function hasValidItemPricing(data) {
      return data.quantity is number && data.quantity > 0 && data.quantity < 1000000 &&
             data.unitPrice is number && data.unitPrice >= 0 && data.unitPrice < 1000000 &&
             data.totalPrice is number && data.totalPrice >= 0 && data.totalPrice < 1000000;
    }

    // Users collection (doc ID = Firebase Auth UID)
    match /users/{userId} {
      // Read: admin, the user themselves, or a kiosk session acting on
      // their behalf (so the kiosk can pre-fill the form).
      allow read: if isAdmin() ||
                     (isSignedIn() && userId == request.auth.uid) ||
                     (actsAs() != '' && actsAs() == userId);

      // Allow creating own user doc during self-registration
      allow create: if isSignedIn() && userId == request.auth.uid &&
                       request.resource.data.permissions is list &&
                       isDocumentReferenceArray(request.resource.data.permissions, 'permission');

      // Users can update their own doc but cannot change roles/permissions.
      // Tag-tap sessions cannot update users at all (their request.auth.uid
      // is synthetic, won't match userId, so the predicate fails).
      // Firma users must provide a valid billing address.
      allow update: if isAdmin() ||
                       (isSignedIn() &&
                        userId == request.auth.uid &&
                        request.resource.data.roles == resource.data.roles &&
                        request.resource.data.permissions == resource.data.permissions &&
                        isValidUserProfile(request.resource.data));

      allow delete: if isAdmin();
    }

    // Permission collection
    match /permission/{permissionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Tokens collection
    match /tokens/{tokenId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Machines collection
    match /machine/{machineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // MaCo (terminals) collection
    match /maco/{deviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Machine usage (from MaCo terminals)
    match /usage_machine/{usageId} {
      allow read: if isAdmin() ||
                     (isSignedIn() && resource.data.userId ==
                       /databases/$(database)/documents/users/$(request.auth.uid)) ||
                     (actsAs() != '' && resource.data.userId ==
                       /databases/$(database)/documents/users/$(actsAs()));
      allow write: if isAdmin();
    }

    // Price lists (public read for QR lookup, admin write)
    match /price_lists/{priceListId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Catalog (unified billable items — public read for QR/material lookup)
    match /catalog/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Checkouts (shopping cart)
    match /checkouts/{checkoutId} {
      // Read: admin, the owner (real or tag-tap), or — for anonymous
      // checkouts — the Firebase Anonymous Auth session that created it.
      // (Anonymous reads are intentionally permissive across all anon
      // sessions; doc IDs are random Firebase IDs so brute-force is
      // impractical, and there is no name/billing in pure-anon checkouts.)
      allow read: if isAdmin() ||
                     isCheckoutPrincipalFor(resource.data.userId) ||
                     (resource.data.userId == null && isAnonymousAuth());

      // Create:
      //  - Anonymous (signed-in via Firebase Anonymous Auth) with userId == null
      //  - Signed-in real/tag with userId matching the authenticated principal
      //
      // Closes Security Analysis §R2 (no more attacker-supplied userId
      // from an unauth client) and the legacy `if true` branch.
      allow create: if (request.resource.data.status == 'open' || request.resource.data.status == 'closed')
        && request.resource.data.keys().hasOnly([
             'userId', 'status', 'usageType', 'created',
             'workshopsVisited', 'persons', 'modifiedBy', 'modifiedAt',
             'closedAt', 'notes', 'summary'
           ])
        && (
             (request.resource.data.userId == null && isAnonymousAuth()) ||
             isCheckoutPrincipalFor(request.resource.data.userId)
           );

      // Update: admin, or the principal of an open checkout. The principal
      // can edit metadata (workshopsVisited, persons, usageType, notes) but
      // CANNOT change status, summary, closedAt, or billRef — those
      // transitions go through closeCheckoutAndGetPayment so the server
      // can recompute prices and allocate a bill atomically.
      allow update: if isAdmin() ||
        (isCheckoutPrincipalFor(resource.data.userId) &&
         resource.data.status == "open" &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
           'status', 'summary', 'closedAt', 'billRef'
         ]));
      allow delete: if isAdmin();

      // Checkout items subcollection
      match /items/{itemId} {
        allow read: if isAdmin() ||
                       isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) ||
                       (get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId == null && isAnonymousAuth());

        // Create / update / delete: principal of an open checkout, or an
        // anonymous-auth session writing to a null-userId checkout. Field
        // validation rejects negative/zero quantities and negative prices
        // (defense-in-depth behind server-side recompute in
        // closeCheckoutAndGetPayment).
        allow create: if (
            isAdmin() ||
            (isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) &&
             get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.status == "open") ||
            (get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId == null && isAnonymousAuth())
          ) && hasValidItemPricing(request.resource.data);
        allow update: if (
            isAdmin() ||
            (isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) &&
             get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.status == "open") ||
            (get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId == null && isAnonymousAuth())
          ) && hasValidItemPricing(request.resource.data);
        allow delete: if isAdmin() ||
            (isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) &&
             get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.status == "open") ||
            (get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId == null && isAnonymousAuth());
      }
    }

    // Config collection (pricing, etc.)
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit log (admin read only, no client writes)
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Bills (server-side only writes, owner + admin reads)
    match /bills/{billId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId ==
          /databases/$(database)/documents/users/$(request.auth.uid)) ||
        (actsAs() != '' && resource.data.userId ==
          /databases/$(database)/documents/users/$(actsAs()));
      allow write: if false;
    }

    // Machine issue reports
    match /machine_reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Login codes (server-only; written + read only by Cloud Functions)
    match /loginCodes/{id} {
      allow read, write: if false;
    }

    // Server-only collections (Cloud Functions writes via Admin SDK bypass
    // these rules; explicit deny for any client attempt).
    match /authentications/{authId} {
      allow read, write: if false;
    }
    match /operations_log/{logId} {
      allow read, write: if false;
    }
  }
}
