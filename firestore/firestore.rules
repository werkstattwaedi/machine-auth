rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Custom claims set by syncCustomClaims Cloud Function
      // when user doc roles[] includes "admin"
      return isSignedIn() && request.auth.token.get('admin', false) == true;
    }

    // The `actsAs` claim is set by verifyTagCheckout on the synthetic-UID
    // custom token used for kiosk badge sessions. It names the real user
    // doc the session is authorized to operate on. Empty string for
    // non-tag sessions.
    function actsAs() {
      return isSignedIn() ? request.auth.token.get('actsAs', '') : '';
    }

    // True for sessions created by Firebase Anonymous Auth
    // (signInAnonymously). The truly-anonymous checkout path uses these
    // — each session has a fresh UID, so rules can scope writes per
    // session even when there's no underlying user record.
    function isAnonymousAuth() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Whether the caller is authorized to act on a checkout owned by the
    // user pointed to by `userRef`. Either a real login (uid == doc.id)
    // or a tag-tap session (actsAs claim == doc.id).
    function isCheckoutPrincipalFor(userRef) {
      return isSignedIn() && (
        userRef == /databases/$(database)/documents/users/$(request.auth.uid) ||
        (actsAs() != '' && userRef == /databases/$(database)/documents/users/$(actsAs()))
      );
    }

    // Validate billing address has all required fields
    function hasValidBillingAddress(data) {
      return data.billingAddress is map &&
             data.billingAddress.company is string && data.billingAddress.company.size() > 0 &&
             data.billingAddress.street is string && data.billingAddress.street.size() > 0 &&
             data.billingAddress.zip is string && data.billingAddress.zip.size() > 0 &&
             data.billingAddress.city is string && data.billingAddress.city.size() > 0;
    }

    // Validate user profile: firma users must have billing address
    function isValidUserProfile(data) {
      return data.userType != 'firma' || hasValidBillingAddress(data);
    }

    // Item-pricing field validation. Server-side recompute in
    // closeCheckoutAndGetPayment is the authoritative defense; this is a
    // cheap rule-level guard that rejects negative quantities/prices and
    // non-finite values (Infinity / NaN). The `is number` check passes
    // for non-finite values, so the explicit < bound is what catches
    // them: `Infinity < 1e308` is false, `NaN < anything` is false.
    //
    // `quantity >= 0` (not > 0) so newly-added catalog items — which start
    // with `quantity: 0` until the user fills in the form — pass the
    // create check. Issue #151: anonymous users now write items to
    // Firestore eagerly, so this code path is exercised by both flows.
    // Final non-zero validation is still done server-side in
    // closeCheckoutAndGetPayment#isValidItem.
    function hasValidItemPricing(data) {
      return data.quantity is number && data.quantity >= 0 && data.quantity < 1000000 &&
             data.unitPrice is number && data.unitPrice >= 0 && data.unitPrice < 1000000 &&
             data.totalPrice is number && data.totalPrice >= 0 && data.totalPrice < 1000000;
    }

    // True when caller and `targetUserId` share the same non-null
    // `activeMembership` ref. Used by `users/{userId}` read to let family
    // co-members see each other's display names for the checkout roster
    // picker. Both docs must already have `activeMembership` populated by
    // the onMembershipWritten trigger; a single rules `get` on the caller's
    // user doc is the per-evaluation cost.
    function shareActiveMembership(targetUserId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(targetUserId)).data.activeMembership != null &&
        get(/databases/$(database)/documents/users/$(targetUserId)).data.activeMembership ==
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeMembership;
    }

    // Same family-roster join as `shareActiveMembership`, but for a
    // kiosk tag-tap session: it reads the membership of the `actsAs()`
    // user (the real principal the synthetic UID acts on) instead of
    // `request.auth.uid` (which has no user doc). Lets a tag-tapped
    // user resolve their own family co-members' docs for the checkout
    // roster picker (issue #422) — exactly the same docs the logged-in
    // owner already sees. The synthetic session still cannot reach any
    // doc outside the tag owner's own active membership.
    function shareActiveMembershipActingAs(targetUserId) {
      return actsAs() != '' &&
        get(/databases/$(database)/documents/users/$(targetUserId)).data.activeMembership != null &&
        get(/databases/$(database)/documents/users/$(targetUserId)).data.activeMembership ==
        get(/databases/$(database)/documents/users/$(actsAs())).data.activeMembership;
    }

    // True when the user pointed to by `userIdRef` has a non-null
    // `activeMembership`. Used to gate the `paymentMethod: "monthly"`
    // write on a closed checkout — only Vereinsmitglieder may roll an
    // open balance onto their monthly bill.
    function hasActiveMembership(userIdRef) {
      return userIdRef != null &&
        get(userIdRef).data.get('activeMembership', null) != null;
    }

    // Users collection (doc ID = Firebase Auth UID)
    match /users/{userId} {
      // Read: admin, the user themselves, a kiosk session acting on their
      // behalf (so the kiosk can pre-fill the form), or a family co-member
      // (so the checkout roster can show display names). The co-member
      // branch is honoured for both a real login (shareActiveMembership)
      // and a tag-tap session acting on the owner's behalf
      // (shareActiveMembershipActingAs) — issue #422.
      allow read: if isAdmin() ||
                     (isSignedIn() && userId == request.auth.uid) ||
                     (actsAs() != '' && actsAs() == userId) ||
                     shareActiveMembership(userId) ||
                     shareActiveMembershipActingAs(userId);

      // Allow creating own user doc during self-registration. Same firma
      // billing-address invariant as the update path — without it a firma
      // account could mint its initial doc address-less and only the
      // invoice-time backstop would catch it.
      //
      // roles/permissions MUST be empty on self-create. Doc ID == Auth UID
      // and syncCustomClaims stamps `admin` on any write whose roles[]
      // includes "admin", so an unconstrained create path let any
      // anonymous/magic-link session self-grant admin (and arbitrary
      // machine permissions). Mirror the update path, which pins both to
      // their prior value: grants must only come through the admin path.
      allow create: if isSignedIn() && userId == request.auth.uid &&
                       request.resource.data.roles == [] &&
                       request.resource.data.permissions == [] &&
                       isValidUserProfile(request.resource.data);

      // Users can update their own doc but cannot change roles/permissions.
      // Tag-tap sessions cannot update users at all (their request.auth.uid
      // is synthetic, won't match userId, so the predicate fails).
      // Firma users must provide a valid billing address.
      allow update: if isAdmin() ||
                       (isSignedIn() &&
                        userId == request.auth.uid &&
                        request.resource.data.roles == resource.data.roles &&
                        request.resource.data.permissions == resource.data.permissions &&
                        isValidUserProfile(request.resource.data));

      allow delete: if isAdmin();
    }

    // Permission collection
    match /permission/{permissionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Tokens collection
    match /tokens/{tokenId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Machines collection
    match /machine/{machineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // MaCo (terminals) collection
    match /maco/{deviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Machine usage (from MaCo terminals)
    match /usage_machine/{usageId} {
      allow read: if isAdmin() ||
                     (isSignedIn() && resource.data.userId ==
                       /databases/$(database)/documents/users/$(request.auth.uid)) ||
                     (actsAs() != '' && resource.data.userId ==
                       /databases/$(database)/documents/users/$(actsAs()));
      allow write: if isAdmin();
    }

    // Price lists (public read for QR lookup, admin write)
    match /price_lists/{priceListId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Catalog (unified billable items — public read for QR/material lookup).
    // Writes must go through the upsertCatalogItem callable so the `code`
    // uniqueness invariant can be enforced in a transaction (impossible
    // to express in rules — they can't query collections). The callable
    // runs with Admin SDK privileges and bypasses these rules; client-side
    // writes are denied even for admins. See ADR-0026.
    match /catalog/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Checkouts (shopping cart)
    match /checkouts/{checkoutId} {
      // Read: admin, the owner (real or tag-tap), or — for anonymous
      // checkouts — the Firebase Anonymous Auth session that CREATED it,
      // scoped per-session via `firebaseUid` (stamped == request.auth.uid
      // on every create). The walk-in flow persists full PII (name, email,
      // billing address) into null-userId checkouts, so an unscoped anon
      // branch let any signInAnonymously() session enumerate every guest's
      // data. `firebaseUid == request.auth.uid` binds the read to the
      // creating session. NB: for a `list` query the rule can only be
      // satisfied when the query itself filters on firebaseUid — which the
      // open-checkout lookup already does.
      allow read: if isAdmin() ||
                     isCheckoutPrincipalFor(resource.data.userId) ||
                     (resource.data.userId == null && isAnonymousAuth() &&
                      resource.data.get('firebaseUid', null) == request.auth.uid);

      // Create:
      //  - Anonymous (signed-in via Firebase Anonymous Auth) with userId == null
      //  - Signed-in real/tag with userId matching the authenticated principal
      //
      // Closes Security Analysis §R2 (no more attacker-supplied userId
      // from an unauth client) and the legacy `if true` branch.
      // Issue #318: every client-side create must stamp `firebaseUid`
      // with the caller's own `request.auth.uid` (anonymous OR
      // signed-in). This gives the abandoned-checkout cleanup a single,
      // generally-applicable join key — and forge protection drops out:
      // a session cannot tag a checkout with anyone else's UID. Admin
      // SDK writes bypass rules and may leave `firebaseUid` null.
      allow create: if (request.resource.data.status == 'open' || request.resource.data.status == 'closed')
        && request.resource.data.keys().hasOnly([
             'userId', 'status', 'usageType', 'created',
             'workshopsVisited', 'persons', 'modifiedBy', 'modifiedAt',
             'firebaseUid',
             'closedAt', 'notes', 'summary'
           ])
        && request.resource.data.get('firebaseUid', null) == request.auth.uid
        && (
             (request.resource.data.userId == null && isAnonymousAuth()) ||
             isCheckoutPrincipalFor(request.resource.data.userId)
           );

      // Update: admin, or the principal of an open checkout. The principal
      // can edit metadata (workshopsVisited, persons, usageType, notes) but
      // CANNOT change status, summary, closedAt, or billRef — those
      // transitions go through closeCheckoutAndGetPayment so the server
      // can recompute prices and allocate a bill atomically.
      //
      // Issue #246: anonymous-auth sessions may also update an open
      // null-userId checkout (e.g. to persist the person roster between
      // step 0 and step 1 so a nav-away-and-back can rehydrate). Same
      // field gate as the principal branch — status/summary/closedAt/
      // billRef must still flow through the callable. No per-session
      // scoping (any anon session can write any null-userId open
      // checkout): doc IDs are random Firebase IDs so this is no worse
      // than the existing items subcollection write rule.
      //
      // Closed-checkout extension (#251): the principal (real, tag, or —
      // for null-userId checkouts — the anonymous-auth caller) can
      // write `paymentMethod` on the closed checkout. Not write-once —
      // the user may switch tabs and the field tracks last selection.
      // The commit-time ack itself lives on the bill and only the
      // server may set it (acknowledgeBill callable / autoAcknowledgeBills
      // cron); clients are denied writes on bills outright.
      //
      // Value validation: `rechnung` or `twint` always; `monthly` only
      // when the user doc has an active membership. Anonymous flow on a
      // null-userId checkout can't consult a membership doc, so monthly
      // is intentionally denied.
      allow update: if isAdmin() ||
        (isCheckoutPrincipalFor(resource.data.userId) &&
         resource.data.status == "open" &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
           'status', 'summary', 'closedAt', 'billRef', 'firebaseUid', 'remindersSent'
         ])) ||
        (resource.data.userId == null && isAnonymousAuth() &&
         resource.data.get('firebaseUid', null) == request.auth.uid &&
         resource.data.status == "open" &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
           'status', 'summary', 'closedAt', 'billRef', 'userId', 'firebaseUid', 'remindersSent'
         ])) ||
        (resource.data.status == "closed" &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'paymentMethod', 'modifiedBy', 'modifiedAt'
         ]) &&
         (
           (isCheckoutPrincipalFor(resource.data.userId) && (
             request.resource.data.paymentMethod in ['rechnung', 'twint'] ||
             (request.resource.data.paymentMethod == 'monthly' &&
              hasActiveMembership(resource.data.userId))
           )) ||
           (resource.data.userId == null && isAnonymousAuth() &&
            resource.data.get('firebaseUid', null) == request.auth.uid &&
            request.resource.data.paymentMethod in ['rechnung', 'twint'])
         ));
      allow delete: if isAdmin();

      // Checkout items subcollection
      match /items/{itemId} {
        // True when the caller is the anonymous-auth session that created
        // the parent null-userId checkout. Scoped per-session via the
        // parent's `firebaseUid` (== creator's request.auth.uid) so one
        // anon session can't reach another's items — mirrors the P0-2
        // parent-checkout read scoping.
        function isAnonParentCreator() {
          return get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId == null &&
                 isAnonymousAuth() &&
                 get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.get('firebaseUid', null) == request.auth.uid;
        }

        allow read: if isAdmin() ||
                       isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) ||
                       isAnonParentCreator();

        // Create / update / delete: principal of an open checkout, or an
        // anonymous-auth session writing to a null-userId checkout. Field
        // validation rejects negative/zero quantities and negative prices
        // (defense-in-depth behind server-side recompute in
        // closeCheckoutAndGetPayment).
        //
        // Badge purchase fields (`tokenId`, `badgeSdmCounter`) are SERVER-
        // written only (addBadgeToCheckout callable, Admin SDK): a client
        // minting/altering an item with a tokenId would let it associate an
        // arbitrary badge at checkout close. Non-admin creates must not
        // carry them; non-admin updates must not touch them. Deletes stay
        // allowed — removing a badge from the cart is legitimate and
        // nothing has been associated yet.
        allow create: if (
            isAdmin() ||
            (
              (
                (isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) &&
                 get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.status == "open") ||
                isAnonParentCreator()
              ) &&
              !request.resource.data.keys().hasAny(['tokenId', 'badgeSdmCounter'])
            )
          ) && hasValidItemPricing(request.resource.data);
        allow update: if (
            isAdmin() ||
            (
              (
                (isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) &&
                 get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.status == "open") ||
                isAnonParentCreator()
              ) &&
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tokenId', 'badgeSdmCounter'])
            )
          ) && hasValidItemPricing(request.resource.data);
        allow delete: if isAdmin() ||
            (isCheckoutPrincipalFor(get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.userId) &&
             get(/databases/$(database)/documents/checkouts/$(checkoutId)).data.status == "open") ||
            isAnonParentCreator();
      }
    }

    // Config collection (pricing, etc.)
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Import state — server-side only (import-job cursors, etc.)
    // Clients have no business reading or writing these operational
    // markers; import jobs run as Cloud Functions with admin SDK access.
    match /import_state/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Audit log (admin read only, no client writes)
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Bills (server-side only writes, owner + admin reads)
    match /bills/{billId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId ==
          /databases/$(database)/documents/users/$(request.auth.uid)) ||
        (actsAs() != '' && resource.data.userId ==
          /databases/$(database)/documents/users/$(actsAs()));
      allow write: if false;
    }

    // Machine issue reports
    match /machine_reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Login codes (server-only; written + read only by Cloud Functions)
    match /loginCodes/{id} {
      allow read, write: if false;
    }

    // Memberships (yearly Vereinsmitgliedschaft, single or family).
    // All mutations go through Cloud Function callables (functions/src/membership/);
    // direct client writes are denied. Reads are scoped to current members and
    // the owner so the family roster UI can populate.
    match /memberships/{membershipId} {
      // Read: admin, any user listed in `members[]`, or a kiosk tag-tap
      // session whose `actsAs()` principal is listed in `members[]`
      // (issue #422 — so a tapped family member can resolve their own
      // roster for the checkout quick-add). The tag branch is scoped to
      // the tag owner's own membership; a synthetic session still cannot
      // read a membership it doesn't belong to, and writes stay
      // callable-only for everyone.
      allow read: if isAdmin() ||
        (isSignedIn() &&
         /databases/$(database)/documents/users/$(request.auth.uid) in resource.data.members) ||
        (actsAs() != '' &&
         /databases/$(database)/documents/users/$(actsAs()) in resource.data.members);

      // No client writes — callables only.
      allow write: if false;

      // Invites (sub-collection, family memberships only).
      match /invites/{inviteId} {
        // Read covers both `get` and `list` — Firestore evaluates the rule
        // per document during a list, so an invitee querying with
        // `where("email", "==", "...")` only sees their own invite, while
        // an unfiltered list by a non-owner is denied for any non-matching
        // document and the whole query fails.
        //   - admin: full access
        //   - membership owner: list/get all invites for their membership
        //   - invitee: get/list an invite whose email matches their auth token
        allow read: if isAdmin() ||
          (isSignedIn() &&
           get(/databases/$(database)/documents/memberships/$(membershipId)).data.ownerUserId ==
           /databases/$(database)/documents/users/$(request.auth.uid)) ||
          (isSignedIn() &&
           request.auth.token.get('email', '') != '' &&
           resource.data.email == request.auth.token.get('email', ''));

        allow write: if false;
      }
    }

    // Label print jobs. Admins enqueue jobs from the browser; the on-LAN
    // gateway (maco_gateway) picks them up via a Firestore service account
    // (which bypasses these rules) and writes the terminal status back.
    // Clients may only create `queued` jobs and read status — never update
    // or delete (status writes are the gateway's; cleanup is via TTL).
    match /printJobs/{jobId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.status == 'queued'
        && request.resource.data.bytesB64 is string
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Server-only collections (Cloud Functions writes via Admin SDK bypass
    // these rules; explicit deny for any client attempt).
    match /authentications/{authId} {
      allow read, write: if false;
    }
    match /operations_log/{logId} {
      allow read, write: if false;
    }
    match /export_state/{streamId} {
      allow read, write: if false;
    }
    match /erasures/{subjectId} {
      allow read, write: if false;
    }
  }
}
